# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database (Supabase Postgres connection string)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PROFESSIONAL_BASE_PRICE_ID=price_...
STRIPE_PROFESSIONAL_PER_USER_PRICE_ID=price_...

# Google Workspace (Phase 1)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft 365 (Phase 2)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# HubSpot CRM
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# Calendly
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=

# Email (Resend)
RESEND_API_KEY=re_...
# Different from addresses for different email types (siggly.io domain is verified)
# These have sensible defaults - only set if you need to override
RESEND_FROM_SUPPORT=Siggly Support <support@siggly.io>
RESEND_FROM_NOREPLY=Siggly <noreply@siggly.io>
RESEND_FROM_SALES=Siggly <sales@siggly.io>
# Inbound email webhook signature verification (get from Resend dashboard → Webhooks)
RESEND_WEBHOOK_SECRET=

# App
# IMPORTANT: Set to https://siggly.io in Vercel production environment variables
# This is used for canonical URLs, OpenGraph tags, and sitemap generation
NEXT_PUBLIC_APP_URL=http://localhost:3000

# HR Sync OAuth Integrations
# OAuth token encryption key (REQUIRED for OAuth integrations)
# Generate with: openssl rand -hex 32
OAUTH_ENCRYPTION_KEY=

# BambooHR OAuth (get from BambooHR Developer Portal)
BAMBOOHR_CLIENT_ID=
BAMBOOHR_CLIENT_SECRET=

# Gusto OAuth (get from https://dev.gusto.com)
GUSTO_CLIENT_ID=
GUSTO_CLIENT_SECRET=

# Rippling OAuth (contact Rippling for API access)
RIPPLING_CLIENT_ID=
RIPPLING_CLIENT_SECRET=

# SEO Engine (optional — engine works without these)
# Google Analytics GA4 property ID (numeric)
GA4_PROPERTY_ID=
# Search Console site URL (e.g., sc-domain:siggly.io)
SEARCH_CONSOLE_SITE_URL=
# Serper.dev API key for competitor SERP data
SERPER_API_KEY=
# Anthropic API key for AI-powered content enhancement (optional)
ANTHROPIC_API_KEY=
# Cron secret for scheduled tasks (set same value in Vercel cron config)
CRON_SECRET=

# Development
# BYPASS_PAY_GATES: server-side pay gate bypass (never expose to client)
# NEXT_PUBLIC_BYPASS_PAY_GATES: client-side UI indicator only (shows badge)
BYPASS_PAY_GATES=true
NEXT_PUBLIC_BYPASS_PAY_GATES=true
